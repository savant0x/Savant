{
    "id": "npm/test",
    "family": "Testing",
    "description": "Compress npm test output. Preserve failures and summary, strip passing noise.",
    "match_criteria": {
        "tool_names": ["npm", "npx", "pnpm", "yarn"],
        "argv_includes": ["test"]
    },
    "filters": {
        "skip_patterns": [
            "^$",
            "^\\s+✓",
            "^\\s+passing",
            "^PASS "
        ],
        "keep_patterns": [
            "^\\s+✗",
            "^\\s+failing",
            "^FAIL ",
            "^AssertionError",
            "^Error:",
            "^\\s+\\d+ (passing|failing|pending)"
        ]
    },
    "transforms": {
        "strip_ansi": true,
        "trim_empty_edges": true,
        "dedupe_adjacent_lines": true
    },
    "summarize": {
        "head_lines": 10,
        "tail_lines": 30,
        "max_chars": 6000
    },
    "failure_mode": "preserve_raw",
    "budget_ms": 5,
    "output_hint": "text"
}
