{
    "id": "git/diff",
    "family": "VersionControl",
    "description": "Compress git diff output. Strip context lines, preserve diff headers and +/- changes.",
    "match_criteria": {
        "tool_names": ["git"],
        "argv_includes": ["diff"]
    },
    "filters": {
        "skip_patterns": [
            "^@@ ",
            "^index ",
            "^--- ",
            "^[+][+][+] ",
            "^diff --git "
        ],
        "keep_patterns": [
            "^[+]",
            "^[-]"
        ]
    },
    "transforms": {
        "strip_ansi": true,
        "trim_empty_edges": true,
        "dedupe_adjacent_lines": true
    },
    "summarize": {
        "head_lines": 100,
        "tail_lines": 20,
        "max_chars": 8000
    },
    "failure_mode": "preserve_raw",
    "budget_ms": 5,
    "output_hint": "text"
}
