{
    "id": "git/branch",
    "family": "VersionControl",
    "description": "Compress git branch output. Strip markers, preserve branch names.",
    "match_criteria": {
        "tool_names": ["git"],
        "argv_includes": ["branch"]
    },
    "filters": {
        "skip_patterns": ["^[*] "]
    },
    "transforms": {
        "strip_ansi": true,
        "trim_empty_edges": true
    },
    "summarize": {
        "head_lines": 50,
        "tail_lines": 5,
        "max_chars": 2000
    },
    "failure_mode": "preserve_raw",
    "budget_ms": 2,
    "output_hint": "text"
}
