          return subprocess.run(cmd, cwd=cwd, check=check, capture_output=True, text=True)
      
      
      def git(*args: str, check: bool = True) -> subprocess.CompletedProcess:
          return run(["git", *args], check=check)
      
      
      def tag_exists(version: str) -> bool:
