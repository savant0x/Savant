              "POST",
              f"/repos/{REPO_SLUG}/releases",
              token,
              {
                  "tag_name": f"v{version}",
                  "target_commitish": "main",
                  "name": f"v{version}",
                  "body": notes,
                  "draft": False,
                  "prerelease": False,
              },
          )
      
      
      def update_release(release_id: int, version: str, notes: str, token: str) -> tuple[int, dict | str]:
