              let vk = self.get_verifying_key()?;
              let sig_bytes = hex::decode(signature).map_err(|_| VaultError::InvalidKeyFormat)?;
              if sig_bytes.len() != 64 {
                  return Err(VaultError::InvalidKeyFormat);
