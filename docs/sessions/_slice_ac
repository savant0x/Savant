        useEffect(() => {
          if (typeof window === "undefined") return;
          const read = (): void => {
            const raw = window.localStorage.getItem(LS_SOUL_BUILT);
            if (!raw) {
              setBuiltSoul(null);
              return;
            }
            try {
              const parsed = JSON.parse(raw) as Partial<BuiltSoulEntry> | null;
              if (!parsed || typeof parsed !== "object") {
                setBuiltSoul(null);
                return;
              }
