const [streamBuffer, setStreamBuffer] = useState<string>("");
const [streamStartTs, setStreamStartTs] = useState<number | null>(null);
const [streamHandle, setStreamHandle] = useState<ManifestStreamHandle | null>(null);
const streamControllerRef = useRef<ManifestStreamHandle | null>(null);

const onManifestSubmit = useCallback(async () => {
  if (!prompt.trim() || submitting) return;
  setSubmitting(true);
  setStatus("pending");
  setError(null);
  setStreamBuffer("");
  setStreamStartTs(Date.now());
  
  const handle = await manifestSoulStream({
    prompt: prompt.trim(),
    name: name.trim() || undefined,
    bootstrap_tier: tier,
    model: modelId ?? "",
  });
  streamControllerRef.current = handle;
  setStreamHandle(handle);
  
  let buffer = "";
  try {
    for await (const event of handle) {
      if (event.type === "preamble" || event.type === "chunk") {
        buffer += event.content ?? event.delta;
        setStreamBuffer(buffer);
      } else if (event.type === "complete") {
        // persist + setBuiltSoul + clear streamBuffer
        const entry: BuiltSoulEntry = { ts: Date.now(), ..., content: event.result.content, ... };
        localStorage.setItem(LS_SOUL_BUILT, JSON.stringify(entry));
        setBuiltSoul(entry);
        setStreamBuffer("");
        setStreamStartTs(null);
        setStatus("ready");
      } else if (event.type === "error") {
        setError(event.error);
        setStatus("degraded");
        setStreamBuffer("");
        setStreamStartTs(null);
      }
    }
  } catch (e) {
    setError(e instanceof Error ? e.message : String(e));
    setStatus("degraded");
  } finally {
    setSubmitting(false);
    streamControllerRef.current = null;
    setStreamHandle(null);
  }
}, [prompt, name, submitting, tier, modelId]);

const onCancelStream = useCallback(() => {
  streamControllerRef.current?.cancel();
  setSubmitting(false);
  setStreamBuffer("");
  setStreamStartTs(null);
  setStatus("ready");
  setError(null);
}, []);
```

