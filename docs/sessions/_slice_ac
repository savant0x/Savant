                  for await (const event of generateSoulStream(
                    prompt,
                    name,
                    tier,
                    masterKey,
                    model,
                    controller.signal,
                  )) {
                    if (controller.signal.aborted) break;
                    channel.send(event);
                    if (
                      event.type === "complete" ||
                      event.type === "error"
                    ) {
                      break;
                    }
                  }
                } catch (e) {
                  if (!controller.signal.aborted) {
                    channel.send({
                      type: "error",
                      error: `Stream failed: ${
                        e instanceof Error ? e.message : String(e)
                      }`,
                    });
                  }
                }
              })();
              return {
                cancel: (): void => {
                  controller.abort();
                },
                done,
              };
