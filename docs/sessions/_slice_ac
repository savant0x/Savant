      export type NameTheme = "mythological" | "sci-fi" | "tech" | "nature" | "abstract";
      
      const MYTHOLOGICAL: readonly string[] = [
        "Prometheus", "Athena", "Nova", "Orion", "Phoenix", "Helios", "Artemis",
