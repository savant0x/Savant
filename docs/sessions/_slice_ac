  content: |
      "use client";
      
      // /manifest — FID-006 v3 Soul Builder.
      //
      // 3 sections in vertical order (v2 reopen 2026-07-13, after Spencer's
      // 8-point feedback on the v1 implementation):
      //   1. Soul Manifestation Engine — builder form (name + die icon +
