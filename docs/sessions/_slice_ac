        // disconnect writes LS_DERIVED; tab B's `storage` event re-hydrates
        // its in-memory `derived` state. Single-tab UX stays consistent.
        useEffect(() => {
          if (typeof window === "undefined") return;
          const onStorage = (e: StorageEvent): void => {
            if (e.key === LS_DERIVED) {
