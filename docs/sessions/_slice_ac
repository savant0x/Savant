       * to `workspace-savant/SOUL.md`.
       */
      export async function manifestSoul(
        payload: SoulManifestPayload,
      ): Promise<ManifestResult> {
        return invoke<ManifestResult>(
          "manifest_soul",
          payload as unknown as Record<string, unknown>,
        );
      }
      
      /**
