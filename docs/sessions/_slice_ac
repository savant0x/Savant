              const prompt = String(payload.prompt ?? "").trim();
              if (!prompt) {
                throw new Error(
                  "Mock IPC: manifest_soul_stream requires `prompt`",
                );
              }
              const name = payload.name?.trim() ? payload.name.trim() : null;
              const tier: BootstrapTier =
                (payload.bootstrap_tier as BootstrapTier | undefined) ??
                "grounded";
              const masterKey = effectiveMasterKey("openrouter");
              const model = String(payload.model ?? "");
