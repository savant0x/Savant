      // src/components/rating-box.tsx
      //
      // Reusable metric display card for the soul builder (FID-006 v3
      // v2 reopen). Shows a label + value + optional 0-1 progress bar
      // + color variant. Used in the Draft Buffer's metadata + rating
      // grids (replaces the single AAA_RATING badge from v1 with a
      // multi-box dashboard per Spencer's "multiple boxes with various
      // metrics" feedback).
      //
      // Color variants map to the existing Tailwind tokens used in
      // the dashboard (border-default/40, border-success/40, etc.).
      
      type RatingColor = "default" | "success" | "warning" | "danger" | "accent";
      
      const RATING_COLOR_CLASS: Record<RatingColor, string> = {
        default: "border-default/40 text-foreground",
        success: "border-success/40 text-success",
        warning: "border-warning/40 text-warning",
        danger: "border-danger/40 text-danger",
        accent: "border-accent/40 text-accent",
      };
      
      const RATING_BAR_CLASS: Record<RatingColor, string> = {
        default: "bg-foreground/60",
        success: "bg-success",
        warning: "bg-warning",
        danger: "bg-danger",
        accent: "bg-accent",
      };
      
      export type RatingBoxProps = {
        /** Uppercase label, e.g. "LINES", "DEPTH", "HASH". */
        label: string;
        /** Primary value (string or number). Rendered bold. */
        value: string | number;
        /** Optional 0-1 progress bar (e.g., depth_score, sections/18). */
        bar?: number;
        /** Color variant for the border + value text + bar. */
        color?: RatingColor;
        /** Optional subtitle shown below the value (e.g., "/18 target"). */
        hint?: string;
        /** Optional title attribute (hover tooltip). */
        title?: string;
      };
      
      export function RatingBox({
        label,
        value,
        bar,
        color = "default",
        hint,
        title,
      }: RatingBoxProps) {
        const barPct =
          bar !== undefined ? Math.max(0, Math.min(1, bar)) * 100 : null;
        return (
          <div
            title={title}
            className={`flex flex-col gap-1.5 rounded-md border ${RATING_COLOR_CLASS[color]} bg-surface/30 p-3`}
          >
            <span className="font-mono text-[9px] font-semibold uppercase tracking-[0.2em] text-muted">
              {label}
            </span>
            <span className="truncate font-mono text-base font-bold">{value}</span>
            {hint && (
              <span className="font-mono text-[9px] text-muted">{hint}</span>
            )}
            {barPct !== null && (
              <div className="mt-1 h-1 w-full overflow-hidden rounded-full bg-surface/60">
                <div
                  className={`h-full ${RATING_BAR_CLASS[color]} transition-all duration-500`}
                  style={{ width: `${barPct}%` }}
                />
              </div>
            )}
          </div>
        );
      }
      
