        // a master key is captured; static 18-section template fallback
        // otherwise). Mirrors savant-orig `execute_manifestation` at
        // [`mod.rs:1718-1982`].
        const onManifestSubmit = useCallback(async (): Promise<void> => {
          const trimmedPrompt = prompt.trim();
          if (!trimmedPrompt || submitting) return;
          setSubmitting(true);
          setStatus("pending");
          setError(null);
          try {
            const result: ManifestResult = await manifestSoul({
              prompt: trimmedPrompt,
              name: name.trim() || undefined,
              // snake_case `bootstrap_tier` to match the Rust IPC field
              // name at `crates/core/src/types/mod.rs:75-79`.
              bootstrap_tier: tier,
              // Optional model hint from the loaded config; the mock
              // falls back to DEFAULT_MODEL if empty.
              model: modelId ?? "",
            });
