                  }
              }
      
              match best_result {
                  Some((agent_id, _, entropy)) => {
                      info!(
                          "HCC: Speculative delegation collapsed on agent {:016x}. Entropy: {:.4}",
                          agent_id, entropy
                      );
                      Ok(())
                  }
