              } else {
                  self.signing_key.clone()
              };
      
              let token = savant_security::SecurityAuthority::mint_quantum_token(
                  &signing_key,
                  &self.pqc_signing_key,
                  subagent_hash,
                  &format!("/workspace/{}", self.session_id),
                  "read",
                  3600,
                  subagent_id,
