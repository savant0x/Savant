        it("returns 8-char hex string (FNV-1a 32-bit output)", () => {
          const h = computeSwarmHashSync(A);
          expect(h).toMatch(/^[0-9a-f]{8}$/);
        });
      });
      
      describe("previewSwarmDiff", () => {
        it("returns 4 empty buckets for two empty arrays", () => {
