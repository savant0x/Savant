      // vitest.setup.ts
      //
      // Global test setup for the renderer. Currently does ONE thing:
      // polyfill `crypto.subtle` from Node's webcrypto, because happy-dom
      // does NOT provide a working SubtleCrypto implementation in many
      // testing environments (FID-009 perfection loop). This affects:
      //   - `src/lib/manifest-mock.ts` `calculateSoulHash` (SHA-256)
      //   - `src/lib/swarm-diff.ts` `computeSwarmHash` (SHA-256)
      //
      // We use `import.meta.vitest` detection to guard the polyfill so
      // the setup file is a no-op in production builds. The polyfill is
      // idempotent — only installs if `crypto.subtle` is missing.
      //
      // Node 19+ ships `globalThis.crypto` natively, but happy-dom still
      // shadows it with its own (incomplete) implementation. Explicit
      // assignment from `node:crypto` `webcrypto` guarantees the full
      // WebCrypto API surface (digest, encrypt, sign, etc.) is present.
      //
      // Future: if we add IndexedDB / localStorage tests, the setup file
      // can also `vi.stubGlobal` those polyfills here.
      
      import { webcrypto } from "node:crypto";
      
      if (!globalThis.crypto || !globalThis.crypto.subtle) {
        // @ts-expect-error — Node's webcrypto is a superset of the
        // browser Crypto interface; the missing methods are browser-only
        // (e.g., getRandomValues with quota) which we don't need in tests.
        globalThis.crypto = webcrypto;
      }
      
