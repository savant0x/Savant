          // a placeholder string. Common placeholders: "TBD", "...",
          // "TODO", "(empty)", "n/a".
          const isPlaceholder = /^\s*(tbd|todo|\.\.\.|\(empty\)|n\/a)\s*$/i.test(
            body.trim(),
