      //
      //   data: {"id":"gen-...","choices":[{"index":0,"delta":{"role":"assistant"},"finish_reason":null}]}
      //
      //   data: {"id":"gen-...","choices":[{"index":0,"delta":{"content":"Hello"},"finish_reason":null}]}
      //
      //   data: {"id":"gen-...","choices":[{"index":0,"delta":{"content":" world"},"finish_reason":null}]}
