                name: `${provider}-default`,
                provider,
                method: "api_key",
                secret_ref_kind: "env",
                base_url:
                  provider === "openrouter" ? "https://openrouter.ai/api/v1" : null,
                updated_at: Math.floor(Date.now() / 1000),
