          /// Updates the personality traits used by the promotion engine.
          pub async fn update_personality(&self, traits: crate::promotion::PersonalityTraits) {
              info!(
                  "MemoryEnclave: personality updated — O:{:.2} C:{:.2} E:{:.2} A:{:.2} N:{:.2}",
                  traits.openness,
