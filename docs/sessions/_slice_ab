            // `manifest_soul` command). Mirrors the gateway handler at
            // `crates/gateway/src/handlers/mod.rs:2031` (generate_template_soul)
            // via the `generate_template_soul` pure function in
            // `./manifest-mock.ts`. Returns the templated SOUL.md body as a
            // string. The manifest page persists the result to localStorage
            // (`LS_SOUL_BUILT`) and shows a Pending→Ready status transition
            // via setTimeout (Phase 1 simulates the async gateway round-trip).
            case "manifest_soul": {
              const payload = args as Partial<SoulManifestPayload>;
              const prompt = String(payload.prompt ?? "").trim();
              if (!prompt) {
                throw new Error("Mock IPC: manifest_soul requires `prompt`");
              }
              const name = payload.name?.trim() ? payload.name.trim() : null;
              // snake_case `bootstrap_tier` matches the Rust IPC field name at
              // `crates/core/src/types/mod.rs:75-79` and the dashboard's
              // `sendControlFrame` payload shape (PB-F).
              const tier = payload.bootstrap_tier ?? null;
              const content = generate_template_soul(prompt, name, today_iso());
              builtSouls.unshift({
                ts: Date.now(),
                prompt,
                name,
                tier,
                content,
              });
