  "content": "// src/components/rating-box.tsx\n//\n// Reusable metric display card for the soul builder (FID-006 v3\n// v2 reopen). Shows a label + value + optional 0-1 progress bar\n// + color variant. Used in the Draft Buffer's metadata + rating\n// grids (replaces the single AAA_RATING badge from v1 with a\n// multi-box dashboard per Spencer's \"multiple boxes with various\n// metrics\" feedback).\n//\n// Color variants map to the existing Tailwind tokens used in\n// the dashboard (border-default/40, border-success/40, etc.).\n\ntype RatingColor = \"default\" | \"success\" | \"warning\" | \"danger\" | \"accent\";\n\nconst RATING_COLOR_CLASS: Record<RatingColor, string> = {\n  default: \"border-default/40 text-foreground\",\n  success: \"border-success/40 text-success\",\n  warning: \"border-warning/40 text-warning\",\n  danger: \"border-danger/40 text-danger\",\n  accent: \"border-accent/40 text-accent\",\n};\n\nconst RATING_BAR_CLASS: Record<RatingColor, string> = {\n  default: \"bg-foreground/60\",\n  success: \"bg-success\",\n  warning: \"bg-warning\",\n  danger: \"bg-danger\",\n  accent: \"bg-accent\",\n};\n\nexport type RatingBoxProps = {\n  /** Uppercase label, e.g. \"LINES\", \"DEPTH\", \"HASH\". */\n  label: string;\n  /** Primary value (string or number). Rendered bold. */\n  value: string | number;\n  /** Optional 0-1 progress bar (e.g., depth_score, sections/18). */\n  bar?: number;\n  /** Color variant for the border + value text + bar. */\n  color?: RatingColor;\n  /** Optional subtitle shown below the value (e.g., \"/18 target\"). */\n  hint?: string;\n  /** Optional title attribute (hover tooltip). */\n  title?: string;\n};\n\nexport function RatingBox({\n  label,\n  value,\n  bar,\n  color = \"default\",\n  hint,\n  title,\n}: RatingBoxProps) {\n  const barPct =\n    bar !== undefined ? Math.max(0, Math.min(1, bar)) * 100 : null;\n  return (\n    <div\n      title={title}\n      className={`flex flex-col gap-1.5 rounded-md border ${RATING_COLOR_CLASS[color]} bg-surface/30 p-3`}\n    >\n      <span className=\"font-mono text-[9px] font-semibold uppercase tracking-[0.2em] text-muted\">\n        {label}\n      </span>\n      <span className=\"truncate font-mono text-base font-bold\">{value}</span>\n      {hint && (\n        <span className=\"font-mono text-[9px] text-muted\">{hint}</span>\n      )}\n      {barPct !== null && (\n        <div className=\"mt-1 h-1 w-full overflow-hidden rounded-full bg-surface/60\">\n          <div\n            className={`h-full ${RATING_BAR_CLASS[color]} transition-all duration-500`}\n            style={{ width: `${barPct}%` }}\n          />\n        </div>\n      )}\n    </div>\n  );\n}\n"
