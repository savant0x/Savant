                  const response = await fetch(OPENROUTER_PROVISION_URL, {
                    method: "POST",
                    headers: {
                      Authorization: `Bearer ${master}`,
                      "Content-Type": "application/json",
                    },
                    body: JSON.stringify(body),
                  });
