        ts: number;
        prompt: string;
        name: string | null;
        tier: string | null;
        content: string;
      };
      
      const STATUS_LABEL: Record<BootstrapStatus, string> = {
        ready: "Ready",
        pending: "Pending",
        degraded: "Degraded",
      };
      
      const STATUS_COLOR: Record<BootstrapStatus, string> = {
        ready: "text-success",
        pending: "text-warning",
        degraded: "text-danger",
      };
      
      const TIER_LABEL: Record<BootstrapTier, string> = {
        pure_generation: "Pure Generation",
        grounded: "Grounded",
        scaffolded: "Scaffolded",
        aspirational: "Aspirational",
      };
      
      const TIER_DESCRIPTION: Record<BootstrapTier, string> = {
        pure_generation:
          "No grounding. LLM hallucinates freely. No manifest.json. (types/mod.rs:1156)",
        grounded:
          "Injected system context. LLM must match reality exactly. (types/mod.rs:1158)",
        scaffolded:
          "Context + LLM can request scaffolding via structured infra block. (types/mod.rs:1160)",
        aspirational:
          "All Tier 3 + unfulfillable claims classified as backlog. (types/mod.rs:1162)",
      };
      
      const DEFAULT_TIER: BootstrapTier = "grounded";
      
      export default function ManifestPage() {
        // Section 1 — builder form state
        const [name, setName] = useState("");
        const [prompt, setPrompt] = useState("");
        const [tier, setTier] = useState<BootstrapTier>(DEFAULT_TIER);
        const [submitting, setSubmitting] = useState(false);
        const [status, setStatus] = useState<BootstrapStatus>("ready");
        const [error, setError] = useState<string | null>(null);
      
        // Section 2 — draft buffer state
        const [builtSoul, setBuiltSoul] = useState<BuiltSoulEntry | null>(null);
      
        // Section 3 — swarm deployment state
        const [bulkJson, setBulkJson] = useState("[]");
        const [bulkSubmitting, setBulkSubmitting] = useState(false);
        const [bulkResult, setBulkResult] = useState<BulkManifestResult | null>(null);
        const [bulkError, setBulkError] = useState<string | null>(null);
      
        // Hydrate Draft Buffer from localStorage on mount + cross-tab sync
        // (same pattern as `LS_DERIVED` in `src/app/chat/page.tsx`).
        useEffect(() => {
          if (typeof window === "undefined") return;
          const read = (): void => {
            const raw = window.localStorage.getItem(LS_SOUL_BUILT);
            if (raw) {
              try {
                setBuiltSoul(JSON.parse(raw) as BuiltSoulEntry);
              } catch {
                setBuiltSoul(null);
              }
            } else {
              setBuiltSoul(null);
            }
          };
          read();
          const onStorage = (e: StorageEvent): void => {
            if (e.key === LS_SOUL_BUILT) read();
          };
          window.addEventListener("storage", onStorage);
          return () => window.removeEventListener("storage", onStorage);
        }, []);
      
        const onManifestSubmit = useCallback(async (): Promise<void> => {
          const trimmedPrompt = prompt.trim();
          if (!trimmedPrompt || submitting) return;
          setSubmitting(true);
          setStatus("pending");
          setError(null);
          try {
            // Phase 1: simulate the async gateway round-trip with a brief
            // setTimeout so the UI can show the Pending→Ready transition
            // (per FID-006 v3 lessons: "Pending/Pending/Degraded exact names").
            await new Promise<void>((resolve) => setTimeout(resolve, 800));
            const content = await manifestSoul({
              prompt: trimmedPrompt,
              name: name.trim() || undefined,
              // snake_case `bootstrap_tier` to match the Rust IPC field name at
              // `crates/core/src/types/mod.rs:75-79` and the dashboard's
              // `sendControlFrame` payload shape (PB-F).
              bootstrap_tier: tier,
            });
            const entry: BuiltSoulEntry = {
              ts: Date.now(),
              prompt: trimmedPrompt,
              name: name.trim() || null,
              tier,
              content,
            };
            if (typeof window !== "undefined") {
              window.localStorage.setItem(LS_SOUL_BUILT, JSON.stringify(entry));
            }
            setBuiltSoul(entry);
            setStatus("ready");
          } catch (e) {
            setError(e instanceof Error ? e.message : String(e));
            setStatus("degraded");
          } finally {
            setSubmitting(false);
          }
        }, [name, prompt, submitting, tier]);
      
        const onRevert = useCallback((): void => {
          if (typeof window !== "undefined") {
            window.localStorage.removeItem(LS_SOUL_BUILT);
          }
          setBuiltSoul(null);
          setStatus("ready");
          setError(null);
        }, []);
      
        const onCopy = useCallback(async (): Promise<void> => {
          if (!builtSoul || typeof window === "undefined") return;
          try {
            await navigator.clipboard.writeText(builtSoul.content);
          } catch (e) {
            setError(
              `Clipboard write failed: ${e instanceof Error ? e.message : String(e)}`,
            );
            setStatus("degraded");
          }
        }, [builtSoul]);
      
        const onBulkDeploy = useCallback(async (): Promise<void> => {
          if (bulkSubmitting) return;
          setBulkSubmitting(true);
          setBulkError(null);
          setBulkResult(null);
          try {
            const parsed: unknown = JSON.parse(bulkJson);
            if (!Array.isArray(parsed)) {
              throw new Error("Bulk JSON must be an array of AgentManifestPlan");
            }
            // Light shape guard — full validation is at the gateway layer
            // (`crates/gateway/src/handlers/mod.rs:645-665` SEC #8).
            for (const a of parsed as AgentManifestPlan[]) {
              if (typeof a?.name !== "string" || typeof a?.soul !== "string") {
                throw new Error(
                  "Each AgentManifestPlan requires `name: string` + `soul: string`",
                );
              }
            }
            const result = await bulkManifest({
              agents: parsed as AgentManifestPlan[],
            });
            setBulkResult(result);
          } catch (e) {
            setBulkError(e instanceof Error ? e.message : String(e));
          } finally {
            setBulkSubmitting(false);
          }
        }, [bulkJson, bulkSubmitting]);
      
        const promptTrimmed = prompt.trim();
        const submitDisabled = !promptTrimmed || submitting;
      
        return (
          <DashboardShell>
            <div className="flex flex-col gap-6">
              {/* ─────────────────────────────────────────────────────────
                  Section 1 — Soul Manifestation Engine (builder form)
                  ───────────────────────────────────────────────────────── */}
              <Card className="flex flex-col gap-4 p-5">
                <header>
                  <p className="font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-muted">
                    Section 1 — Soul Manifestation Engine
                  </p>
                  <h2 className="mt-1 font-mono text-base font-semibold uppercase tracking-[0.18em]">
                    Build a new soul
                  </h2>
                  <p className="mt-2 text-xs text-muted">
                    Dispatches{" "}
                    <code className="rounded bg-surface px-1.5 py-0.5 font-mono text-[11px] text-accent">
                      ControlFrame::SoulManifest
                    </code>{" "}
                    (pasteback: <code>crates/core/src/types/mod.rs:75</code>). Phase 1
                    runs in browser via the mock IPC; Phase 2 writes to
                    <code className="rounded bg-surface px-1.5 py-0.5 font-mono text-[11px] text-accent">
                      workspace-savant/SOUL.md
                    </code>
                    .
                  </p>
                </header>
      
                <div className="grid grid-cols-1 gap-4 md:grid-cols-2">
                  <label className="flex flex-col gap-1.5">
                    <span className="font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-muted">
                      Soul Name
                    </span>
                    <input
                      type="text"
                      value={name}
                      onChange={(e) => setName(e.target.value)}
                      placeholder="Unnamed Agent"
                      className="rounded-md border border-[color:var(--input-border-color)] bg-surface/30 px-3 py-2 font-mono text-sm text-foreground placeholder:text-muted focus:border-accent focus:outline-none"
                    />
